  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#64748b"
      }
    },
    {
      "name": "Keyword - 主蓝加粗",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#0284c7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator - 视觉退后",
      "scope": [
        "keyword.operator",
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#475569"
      }
    },
    {
      "name": "Function - 发光感",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#0369a1"
      }
    },
    {
      "name": "Number, Constant - 月光黄",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#b45309"
      }
    },
    {
      "name": "String - 月灵花绿",
      "scope": [
        "string",
        "string.quoted.single",
        "string.quoted.double",
        "text.html.vue string"
      ],
      "settings": {
        "foreground": "#059669"
      }
    },
    {
      "name": "String Interpolation - 发光蓝",
      "scope": [
        "meta.embedded",
        "source.js.embedded",
        "string.template meta.template.expression"
      ],
      "settings": {
        "foreground": "#0369a1"
      }
    },
    {
      "name": "Class, Type - 暖色点缀",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#b45309"
      }
    },
    {
      "name": "Tag - 错误红",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "text.html.vue entity.name.tag",
        "meta.tag.vue"
      ],
      "settings": {
        "foreground": "#b91c1c"
      }
    },
    {
      "name": "Attributes - 主蓝",
      "scope": [
        "entity.other.attribute-name",
        "text.html.vue entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#0284c7"
      }
    },
    {
      "name": "Regular Expressions - 青色点缀",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#0e7490"
      }
    },
    {
      "name": "URL - 下划线",
      "scope": [
        "*url*",
        "*link*",
        "*uri*"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#b91c1c"
      }
    },
    {
      "name": "Inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#059669"
      }
    },
    {
      "name": "Deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#b91c1c"
      }
    },
    {
      "name": "Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#b45309"
      }
    },
    {
      "name": "TODO Highlight",
      "scope": [
        "comment.line.todo",
        "comment.block.todo"
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables - 局部变量 (退后)",
      "scope": [
        "variable.other.readwrite.local",
        "variable.other.local",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#1e293b"
      }
    },
    {
      "name": "Variables - 参数 (斜体退后)",
      "scope": [
        "variable.parameter",
        "variable.other.parameter"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#475569"
      }
    },
    {
      "name": "Variables - 常量/全局 (保持亮度)",
      "scope": [
        "variable.other.constant",
        "variable.other.global",
        "variable.other.readwrite.global"
      ],
      "settings": {
        "foreground": "#1e293b",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables - 成员属性",
      "scope": [
        "variable.other.property",
        "variable.other.member"
      ],
      "settings": {
        "foreground": "#64748b"
      }
    },
    {
      "name": "Destructuring - 解构变量",
      "scope": [
        "variable.other.destructuring"
      ],
      "settings": {
        "foreground": "#475569"
      }
    },
    {
      "name": "Object Keys - 普通键名 (退后)",
      "scope": [
        "meta.object.key",
        "meta.object-literal.key",
        "string.unquoted.label",
        "meta.object.key.js",
        "meta.object.key.ts"
      ],
      "settings": {
        "foreground": "#475569"
      }
    },
    {
      "name": "Object Keys - 常量键名 (保持亮度)",
      "scope": [
        "meta.object.key constant",
        "meta.object.key constant.other"
      ],
      "settings": {
        "foreground": "#1e293b",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Object Keys - 嵌套键名 (更退后)",
      "scope": [
        "meta.object.key meta.object.key",
        "meta.object.key.nested"
      ],
      "settings": {
        "foreground": "#64748b"
      }
    },
    {
      "name": "Key-Value Separator - 冒号 (视觉退后)",
      "scope": [
        "punctuation.separator.key-value",
        "punctuation.separator.mapping.key-value"
      ],
      "settings": {
        "foreground": "#475569"
      }
    },
    {
      "name": "Method Call - 第一层 (发光感)",
      "scope": [
        "meta.method-call entity.name.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#0369a1"
      }
    },
    {
      "name": "Method Call - 链式后续 (退后)",
      "scope": [
        "meta.method-call meta.method-call entity.name.function",
        "meta.function-call meta.function-call entity.name.function",
        "meta.chain entity.name.function"
      ],
      "settings": {
        "foreground": "#475569"
      }
    },
    {
      "name": "Method Call - 深层链式 (更退后)",
      "scope": [
        "meta.method-call meta.method-call meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#64748b"
      }
    },
    {
      "name": "Method Chain Separator - 点操作符",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.dot"
      ],
      "settings": {
        "foreground": "#475569"
      }
    },
    {
      "name": "Array - 元素",
      "scope": [
        "meta.array.element"
      ],
      "settings": {
        "foreground": "#475569"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#0369a1"
      }
    },
    {
      "name": "CSS Units",
      "scope": [
        "keyword.other.unit.css",
        "keyword.other.unit.rem.css",
        "keyword.other.unit.px.css",
        "keyword.other.unit.em.css",
        "keyword.other.unit.percent.css"
      ],
      "settings": {
        "foreground": "#b45309"
      }
    },
    {
      "name": "CSS Variable Definitions",
      "scope": [
        "meta.property-list.css variable",
        "source.css variable",
        "variable.css"
      ],
      "settings": {
        "foreground": "#0369a1"
      }
    },
    {
      "name": "CSS Variable Usage",
      "scope": [
        "meta.function.css variable",
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#0369a1"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#0284c7"
      }
    },
    {
      "name": "CSS Pseudo",
      "scope": [
